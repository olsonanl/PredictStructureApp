# Dockerfile for predict-structure — all-in-one with all prediction tools
#
# Single GPU container with predict-structure CLI and all four tools
# installed in separate conda environments. Uses the subprocess backend
# with tool executables at /opt/conda-<tool>/bin/*.
#
# For HPC, convert to Apptainer: singularity build predict-structure-all.sif \
#   docker://dxkb/predict-structure-all:latest-gpu
#
# Build:
#   docker build --platform linux/amd64 \
#     -t dxkb/predict-structure-all:latest-gpu \
#     -f container/Dockerfile.predict-structure-all .
#
# Run:
#   docker run --gpus all -v $(pwd)/data:/input -v $(pwd)/output:/output \
#     dxkb/predict-structure-all:latest-gpu \
#     auto /input/protein.fasta -o /output
#
# Run specific tool:
#   docker run --gpus all -v $(pwd)/data:/input -v $(pwd)/output:/output \
#     dxkb/predict-structure-all:latest-gpu \
#     boltz /input/protein.fasta -o /output --use-msa-server

ARG CUDA_VERSION=12.1.0

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu22.04

LABEL maintainer="BV-BRC Team"
LABEL description="Unified protein structure prediction — all tools in one container"
LABEL org.opencontainers.image.source="https://github.com/CEPI-dxkb/PredictStructureApp"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
ENV PYTHONUNBUFFERED=1

# ─── System dependencies ─────────────────────────────────────────────

RUN apt-get update && apt-get install -y --no-install-recommends \
        wget \
        git \
        gcc \
        g++ \
        make \
        libyaml-dev \
        libffi-dev \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ─── Miniconda ────────────────────────────────────────────────────────

ENV CONDA_DIR=/opt/conda
RUN wget -q https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O /tmp/miniconda.sh && \
    bash /tmp/miniconda.sh -b -p $CONDA_DIR && \
    rm /tmp/miniconda.sh
ENV PATH=$CONDA_DIR/bin:$PATH

# ─── Per-tool conda environments ─────────────────────────────────────
#
# Each tool gets its own environment to avoid dependency conflicts.
# Executables are at /opt/conda-<tool>/bin/<executable>.

# --- Boltz-2 ---
RUN conda create -y -p /opt/conda-boltz python=3.11 && \
    /opt/conda-boltz/bin/pip install --no-cache-dir boltz[cuda] && \
    conda clean -afy

# --- Chai-1 ---
RUN conda create -y -p /opt/conda-chai python=3.11 && \
    /opt/conda-chai/bin/pip install --no-cache-dir chai_lab && \
    conda clean -afy

# --- ESMFold (HuggingFace) ---
RUN conda create -y -p /opt/conda-esmfold python=3.11 && \
    /opt/conda-esmfold/bin/pip install --no-cache-dir \
        'torch>=2.6' transformers accelerate biopython && \
    conda clean -afy

# --- AlphaFold 2 ---
# AlphaFold uses a fixed install path; database dir is mounted at runtime.
RUN conda create -y -p /opt/conda-alphafold python=3.11 && \
    git clone --depth 1 https://github.com/google-deepmind/alphafold.git /app/alphafold && \
    cd /app/alphafold && \
    /opt/conda-alphafold/bin/pip install --no-cache-dir -r requirements.txt && \
    /opt/conda-alphafold/bin/pip install --no-cache-dir . && \
    conda clean -afy

# ─── predict-structure CLI ────────────────────────────────────────────
#
# Installed into a dedicated env. This is what the user calls.

RUN conda create -y -p /opt/conda-predict python=3.12 && \
    conda clean -afy

WORKDIR /app/predict-structure
COPY pyproject.toml README.md ./
COPY predict_structure/ predict_structure/

RUN /opt/conda-predict/bin/pip install --no-cache-dir -e ".[all]"

# Symlink predict-structure into /usr/local/bin for easy access
RUN ln -sf /opt/conda-predict/bin/predict-structure /usr/local/bin/predict-structure

# Copy app specs, CWL, and test data
COPY app_specs/ /app/predict-structure/app_specs/
COPY cwl/ /app/predict-structure/cwl/
COPY test_data/ /app/predict-structure/test_data/

# ─── Directories ──────────────────────────────────────────────────────

RUN mkdir -p /input /output /databases /cache && \
    chmod 777 /cache

# Cache dirs for tools that download models at runtime
ENV BOLTZ_CACHE=/cache
ENV CHAI_DOWNLOADS_DIR=/cache
ENV HF_HOME=/cache/huggingface
ENV TORCH_HOME=/cache/torch

# ─── Entrypoint ───────────────────────────────────────────────────────

WORKDIR /data

ENTRYPOINT ["predict-structure"]
CMD ["--help"]
