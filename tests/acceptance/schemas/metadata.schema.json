{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PredictStructure metadata.json",
  "description": "Execution metadata from structure prediction.",
  "type": "object",
  "required": ["tool"],
  "properties": {
    "tool": {
      "type": "string",
      "enum": ["boltz", "openfold", "chai", "alphafold", "esmfold"],
      "description": "Tool that produced the prediction."
    },
    "runtime_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Wall-clock runtime in seconds."
    },
    "version": {
      "type": "string",
      "description": "Tool or predict-structure version."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of prediction."
    },
    "params": {
      "type": "object",
      "description": "Parameters used for the prediction."
    }
  },
  "additionalProperties": true
}
