{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PredictStructure confidence.json",
  "description": "Standardized confidence metrics from structure prediction.",
  "type": "object",
  "required": ["plddt_mean", "per_residue_plddt"],
  "properties": {
    "plddt_mean": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Average per-residue pLDDT score (0-100 scale)."
    },
    "ptm": {
      "description": "Predicted TM-score (0-1 scale), or null if unavailable.",
      "oneOf": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "null"}
      ]
    },
    "per_residue_plddt": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number",
        "minimum": 0,
        "maximum": 100
      },
      "description": "Per-residue pLDDT array (0-100 scale)."
    }
  },
  "additionalProperties": true
}
