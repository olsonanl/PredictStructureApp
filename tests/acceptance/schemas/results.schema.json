{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PredictStructure results.json",
  "description": "Denormalized summary + file manifest for a prediction run. Written post-normalization; re-reads metadata.json and confidence.json for canonical fields.",
  "type": "object",
  "required": ["schema_version", "tool", "version", "status", "timestamp", "outputs"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Schema version (semver-lite: major.minor)."
    },
    "tool": {
      "type": "string",
      "description": "Prediction tool name (e.g. boltz, chai, esmfold, openfold, alphafold)."
    },
    "version": {
      "type": "string",
      "description": "predict-structure package version."
    },
    "tool_version": {
      "oneOf": [{"type": "string"}, {"type": "null"}],
      "description": "Underlying model/tool version (best-effort)."
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "runtime_seconds": {
      "oneOf": [{"type": "number", "minimum": 0}, {"type": "null"}]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "source"],
        "properties": {
          "kind": {"type": "string", "enum": ["protein", "dna", "rna", "ligand", "smiles", "glycan", "msa"]},
          "source": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "length": {"type": "integer", "minimum": 0},
          "name": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "command": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Exact CLI argv, joinable with spaces for reproduction."
    },
    "container_image": {
      "oneOf": [{"type": "string"}, {"type": "null"}],
      "description": "Container image path or digest; null for native runs."
    },
    "backend": {
      "oneOf": [{"type": "string"}, {"type": "null"}]
    },
    "metrics": {
      "type": "object",
      "description": "Scalar summary metrics. Arrays stay in confidence.json.",
      "properties": {
        "plddt_mean": {"oneOf": [{"type": "number", "minimum": 0, "maximum": 100}, {"type": "null"}]},
        "ptm": {"oneOf": [{"type": "number", "minimum": 0, "maximum": 1}, {"type": "null"}]},
        "num_residues": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "num_atoms": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]}
      },
      "additionalProperties": true
    },
    "outputs": {
      "type": "array",
      "description": "Manifest of every artifact in the output directory (raw/ treated as one opaque dir entry).",
      "items": {
        "type": "object",
        "required": ["path", "role"],
        "properties": {
          "path": {"type": "string", "description": "POSIX-relative path from output_dir."},
          "size": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
          "sha256": {"oneOf": [{"type": "string", "pattern": "^[0-9a-f]{64}$"}, {"type": "null"}]},
          "role": {"type": "string", "enum": ["structure", "confidence", "metadata", "summary", "provenance", "report", "raw_dir", "auxiliary"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
